<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Core permissions -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />

    <!--
        ACCESS_BACKGROUND_LOCATION is required on Android 10+ if you want the
        SDK to keep collecting while the screen is locked or the user switches
        apps. Without it, Android stops delivering GPS updates to the
        FusedLocationProviderClient once the app leaves the foreground.

        Google Play requires a separate runtime prompt for this permission
        (requested in MainActivity after ACCESS_FINE_LOCATION is granted) and a
        policy disclosure explaining why background location is needed.
    -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!--
        FOREGROUND_SERVICE is required to call startForeground() on API 28+.
        FOREGROUND_SERVICE_LOCATION is additionally required on Android 14+ (API 34)
        for any foreground service that accesses location.
    -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <application
        android:name=".AsphaltDemoApplication"
        android:label="Asphalt Demo"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar"
        android:usesCleartextTraffic="true">
        <!--
            usesCleartextTraffic="true" is for debug builds only (emulator/local server
            uses http). For production, use network_security_config.xml to restrict
            cleartext to localhost only, or remove this attribute and use HTTPS.
        -->

        <!--
            foregroundServiceType="location" is required on Android 10+ for any
            foreground service that requests location updates. The system will
            throw a SecurityException at runtime if this attribute is missing.
        -->
        <service
            android:name=".DetectionForegroundService"
            android:foregroundServiceType="location"
            android:exported="false" />

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
